FROM ubuntu:noble-20260410

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends \
       gcc \
       g++ \
       cmake \
       make \
       libopenblas-dev \
       python3-pip \
       python3-dev \
    && rm -rf /var/lib/apt/lists/*

# Build llama-cpp-python with OpenBLAS for CPU acceleration. The CMake flag
# names changed in llama.cpp 0.3.x — LLAMA_* became GGML_*.
COPY requirements-container.txt /tmp/requirements-container.txt
RUN CMAKE_ARGS="-DGGML_BLAS=ON -DGGML_BLAS_VENDOR=OpenBLAS" FORCE_CMAKE=1 \
    pip install --no-cache-dir --break-system-packages \
    -r /tmp/requirements-container.txt
